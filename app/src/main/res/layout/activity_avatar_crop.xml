<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111">

    <com.example.facecheck.ui.face.TouchImageView
        android:id="@+id/ivAvatarCrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="头像裁剪"
        android:scaleType="matrix" />

    <com.example.facecheck.ui.face.CircleCropOverlayView
        android:id="@+id/avatarCropOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#CC111111"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <Button
            android:id="@+id/btnAvatarCropCancel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="取消" />

        <Space
            android:layout_width="12dp"
            android:layout_height="1dp" />

        <Button
            android:id="@+id/btnAvatarCropConfirm"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="确认裁剪" />
    </LinearLayout>

</FrameLayout>
